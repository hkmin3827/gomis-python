# Javis Motion Control — 환경변수 예시
# 이 파일을 복사해서 .env 파일로 사용하세요: copy .env.example .env
# .env 파일은 절대 git에 커밋하지 마세요.

# Anthropic API 키 (Claude 연동에 필요)
# https://console.anthropic.com 에서 발급
ANTHROPIC_API_KEY=sk-ant-***

# 카메라 설정 (기본값: 0번 카메라)
CAMERA_INDEX=0

# Whisper 모델 크기 (tiny/base/small/medium/large)
# tiny: 가장 빠름, 정확도 보통
# base: 속도/정확도 균형 (권장)
# small: 정확도 높음, GPU 권장
WHISPER_MODEL=base

# 제스처 감도 (0.1 ~ 1.0, 기본값: 0.5)
GESTURE_SENSITIVITY=0.5
